@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container mt-5">

    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">🔒 Privacy Policy</h3>
        </div>

        <div class="card-body p-4">

            <p>
                SupportSphere is committed to protecting user privacy and ensuring
                the security of customer support information.
            </p>

            <h5>Information We Collect</h5>
            <ul>
                <li>User account information (Email Address)</li>
                <li>Support ticket details</li>
                <li>Feedback and ratings submitted by users</li>
            </ul>

            <h5>How We Use Information</h5>
            <ul>
                <li>To manage customer support requests</li>
                <li>To track ticket status and resolutions</li>
                <li>To improve customer service quality</li>
            </ul>

            <h5>Data Security</h5>
            <p>
                User information is stored securely and access is restricted
                based on user roles and authorization policies.
            </p>

            <h5>User Rights</h5>
            <p>
                Users can view, update, and manage their support tickets
                through the SupportSphere platform.
            </p>

        </div>

    </div>

</div>