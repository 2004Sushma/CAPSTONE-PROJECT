@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-4">

    <div class="text-center mb-5">
        <h1 class="dashboard-title">Admin Dashboard</h1>
        <p class="text-muted">Manage tickets, feedback and reports</p>
    </div>

    <div class="row g-4">

        <div class="col-md-3">
            <div class="dashboard-card">
                <div class="icon">🎫</div>
                <h4>Manage Tickets</h4>
                <p>View and manage all customer tickets.</p>

                <a asp-controller="Admin"
                       asp-action="AllTickets"
                       class="btn btn-primary">
                    Open
                </a>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-card">
                <div class="icon">🛠️</div>
                <h4>Resolve Tickets</h4>
                <p>Track and resolve pending tickets.</p>

                <a asp-controller="Admin"
                       asp-action="ResolveTickets"
                       class="btn btn-success">
                    Open
                </a>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-card">
                <div class="icon">⭐</div>
                <h4>Feedback</h4>
                <p>Review customer feedback and ratings.</p>

                <a asp-controller="Feedbacks"
                       asp-action="Index"
                       class="btn btn-warning">
                    Open
                </a>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-card">
                <div class="icon">📊</div>
                <h4>Reports</h4>
                <p>View ticket analytics and reports.</p>

                <a asp-controller="Admin"
                       asp-action="Reports"
                       class="btn btn-danger">
                    Open
                </a>
            </div>
        </div>

    </div>

</div>