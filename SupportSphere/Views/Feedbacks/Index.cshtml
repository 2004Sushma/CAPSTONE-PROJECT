@model IEnumerable<SupportSphere.Models.Feedback>

@{
    ViewData["Title"] = "Customer Feedback";
}

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold">⭐ Customer Feedback</h1>
            <p class="text-muted">Review customer ratings and comments</p>
        </div>
    </div>

    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-header text-white"
             style="background-color:#001845;">
            <h4 class="mb-0">Feedback Records</h4>
        </div>

        <div class="card-body p-0">

            <table class="table table-hover align-middle mb-0">
                <thead style="background-color:#001845;color:white;">
                    <tr>
                        <th>Rating</th>
                        <th>Comments</th>
                        <th>Ticket</th>
                        <th width="180">Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>
                                <span class="badge bg-warning text-dark fs-6">
                                    ⭐ @item.Rating
                                </span>
                            </td>

                            <td>
                                @item.Comments
                            </td>

                            <td>
                                @item.Ticket?.Title
                            </td>

                            <td>
                                <a asp-action="Details"
                                       asp-route-id="@item.FeedbackId"
                                       class="btn btn-primary btn-sm">
                                    👁 View Feedback
                                </a>
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>